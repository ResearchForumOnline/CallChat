[Unit]
Description=CallChat Zero Agent Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/callchat
EnvironmentFile=/etc/callchat/zero-agent.env
ExecStart=/usr/bin/python3 /opt/callchat/ai/zero_agent_bridge.py
Restart=always
RestartSec=3
User=callchat
Group=callchat
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
