# Copy to .env and replace every CHANGE_ME value before starting.

SERVER_NAME=example.com
PUBLIC_BASEURL=https://matrix.example.com/
SYNAPSE_REPORT_STATS=no

POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

SYNAPSE_CONFIG_PATH=/data/homeserver.yaml
SYNAPSE_DATA_PATH=/data

# Optional TURN settings. Keep shared secrets private.
TURN_URIS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
TURN_SHARED_SECRET=CHANGE_ME_TURN_SHARED_SECRET
TURN_USER_LIFETIME=86400000
