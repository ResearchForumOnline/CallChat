ZERO_AGENT_HOST=127.0.0.1
ZERO_AGENT_PORT=8787
OPENZERO_BASE_URL=http://127.0.0.1:1024
OPENZERO_API_KEY=
OPENZERO_MODEL=gemma4:e4b
# AI route: local, openai, or groq. Cloud keys remain server-side.
CALLCHAT_AI_PROVIDER=local
CALLCHAT_OPENAI_API_KEY=
CALLCHAT_OPENAI_MODEL=gpt-5.5
CALLCHAT_GROQ_API_KEY=
CALLCHAT_GROQ_MODEL=qwen/qwen3-32b
CALLCHAT_PROVIDER_STORE=/var/lib/callchat-openzero-bridge/provider-secrets.json
ALLOWED_ORIGINS=https://example.com,https://www.example.com
ZERO_AGENT_DAILY_LIMIT=40
SITE_CONTEXT=CallChat Community helps people self-host Matrix/Synapse/Element with optional OpenZero AI support.
# Optional provider-isolated IonQ assurance receipts. Never expose this key in browser JavaScript.
CALLCHAT_IONQ_API_KEY=
CALLCHAT_IONQ_BACKEND=simulator
CALLCHAT_IONQ_ALLOW_PAID_QPU=false
