# Copy this file to /root/callchat-secrets/callchat-zero-bot.env on the server.
# Do not commit the real env file.

MATRIX_HOMESERVER=https://callchat.org
MATRIX_USER_ID=@zero:callchat.org
MATRIX_USERNAME=zero
MATRIX_PASSWORD=replace-with-private-bot-password
# MATRIX_ACCESS_TOKEN=

# Comma-separated room IDs or aliases. Keep empty until the bot is invited and tested.
CALLCHAT_BOT_ALLOWED_ROOMS=#zero-bot-lab:callchat.org
CALLCHAT_BOT_ALLOW_ALL_ROOMS=false
CALLCHAT_BOT_MENTION_RESPONSES=true
CALLCHAT_BOT_AMBIENT_RESPONSES=true
CALLCHAT_BOT_RATE_SECONDS=8
CALLCHAT_BOT_USER_RATE_BURST=5
CALLCHAT_BOT_USER_RATE_WINDOW_SECONDS=60
CALLCHAT_BOT_ROOM_RATE_BURST=40
CALLCHAT_BOT_ROOM_RATE_WINDOW_SECONDS=60
CALLCHAT_BOT_RATE_NOTICE_SECONDS=60
# Comma-separated Matrix IDs that bypass bot reply limits, if ever needed.
CALLCHAT_BOT_RATE_EXEMPT_USERS=
CALLCHAT_BOT_BUFFER_MESSAGES=30
CALLCHAT_BOT_MAX_PROMPT_CHARS=2600

# Local OpenZero brain. Use an API key only if OpenZero requires one.
OPENZERO_LLM_URL=http://127.0.0.1:1024/v1/chat/completions
OPENZERO_MODEL=qwen3:4b
OPENZERO_API_KEY=
OPENZERO_TIMEOUT_SECONDS=120

# Optional local voice output. Leave VOICEBOX_URL empty to disable voice.
VOICEBOX_URL=http://127.0.0.1:17493
VOICEBOX_ENDPOINT=/generate
VOICEBOX_PROFILE=callchat-zero
VOICEBOX_LANGUAGE=en
VOICEBOX_TIMEOUT_SECONDS=45

ZERO_BOT_PERSONA=sharp
ZERO_BOT_SITE_NAME=CallChat ZERO
ZERO_BOT_KNOWLEDGE_FILE=/opt/callchat-zero-bot/callchat_knowledge.json
